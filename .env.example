# ===========================================
# AUTH - JWT Secret
# ===========================================
# Generate with: openssl rand -base64 32
# IMPORTANT: Use different secrets for dev and prod!
AUTH_SECRET=your-secret-key-min-32-chars-here

# ===========================================
# DATABASE - Turso (Development)
# ===========================================
# These are used by the app AND by `npm run db:push`
# 1. Install CLI: brew install tursodatabase/tap/turso
# 2. Login: turso auth login
# 3. Create dev DB: turso db create pos-dev
# 4. Get URL: turso db show pos-dev --url
# 5. Get token: turso db tokens create pos-dev
TURSO_DATABASE_URL=libsql://pos-dev-yourname.turso.io
TURSO_AUTH_TOKEN=eyJ...your-dev-token

# ===========================================
# DATABASE - Turso (Production) - Optional
# ===========================================
# Only needed for `npm run db:push:prod`
# Create prod DB: turso db create pos
# TURSO_PROD_DATABASE_URL=libsql://pos-yourname.turso.io
# TURSO_PROD_AUTH_TOKEN=eyJ...your-prod-token

# ===========================================
# AI Features (optional)
# ===========================================
# OpenAI - Product identification (GPT-4o Mini Vision)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# fal.ai - Emoji icon generation
# Get from: https://fal.ai/dashboard/keys
FAL_KEY=your-fal-api-key

# ===========================================
# STORAGE - No additional config needed!
# ===========================================
# In development: Files saved to public/media/ (gitignored)
# In production: Icons stored as base64 in Turso database
